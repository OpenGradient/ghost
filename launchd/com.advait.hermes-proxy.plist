<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.advait.hermes-proxy</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>__HOME__/.ghost/privacy/rotating_proxy.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.ghost/privacy/proxy.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.ghost/privacy/proxy.err.log</string>
</dict>
</plist>
