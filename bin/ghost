#!/bin/sh
# ghost -- incognito agentic harness launcher (profile: uncensored).
#   Default model: hosted nous/hermes-4-405b, reached through ghost's local OHTTP bridge
#     (127.0.0.1:8788) -> PII scrubber -> chat-api TEE gateway (oblivious-HTTP + enclave).
#   On-demand via /model: drops to the fully-local 32B/7B (true incognito, nothing leaves).
# Warns (never hard-blocks) if the privacy infra is down or you're not logged in, so the
# offline local model still runs.
SCRUBBER="http://127.0.0.1:8788"
PROXY="http://127.0.0.1:8899"
PY=__PYTHON__
SENTINEL="__GHOST_HOME__/privacy/.pass_paths"
export HERMES_HOME="__GHOST_HOME__"   # ghost's isolated state dir (the engine honors HERMES_HOME)

# Strip an ambient ANTHROPIC_API_KEY so any `claude` the agent shells out to uses your
# Claude subscription (OAuth) instead of an empty-credit pay-per-use API key. ghost itself
# infers through the OG TEE gateway and never needs this key.
unset ANTHROPIC_API_KEY

# --paths (or --code): path-aware mode -- let real filesystem paths reach the hosted model
# for agentic file work; name + secrets in content are still scrubbed. Default off = full redaction.
PASS_PATHS=""
case "${1:-}" in --paths|--code) PASS_PATHS=1; shift ;; esac

# Are we connected to a hosted account?  (hosted models need `ghost-login`.)
if "$PY" "__GHOST_HOME__/privacy/chat_login.py" --status >/dev/null 2>&1; then LOGIN="✅ connected"; else LOGIN="⚠️ not logged in (run: ghost-login)"; fi

# Self-heal the hosted inference route through the scrubber (a token refresh can reset it).
"$PY" "__GHOST_HOME__/privacy/ensure_scrubber_route.py" 2>/dev/null || true

# Is the local OHTTP bridge up?  (it's what carries hosted requests.)
HC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$SCRUBBER/healthz" 2>/dev/null)

if [ -f "__GHOST_HOME__/.ghost-direct" ]; then
  # Direct mode: OHTTP bridge talks to chat-api directly (no Webshare rotation).
  if [ "$HC" = "200" ]; then
    STATUS="👻 ghost · direct · default = Hermes 405B via TEE gateway (OHTTP) · $LOGIN · local 32B fallback"
  else
    STATUS="👻 ghost · ⚠️ OHTTP bridge DOWN (scrubber=$HC) -- hosted unreachable, falling back to LOCAL 32B (offline)"
  fi
else
  EXIT_IP=$(/usr/bin/curl -s --max-time 8 -x "$PROXY" https://api.ipify.org 2>/dev/null)
  if [ "$HC" = "200" ] && [ -n "$EXIT_IP" ]; then
    STATUS="👻 ghost · default = Hermes 405B via TEE gateway (OHTTP) · relayed via $EXIT_IP · $LOGIN · local 32B fallback"
  else
    STATUS="👻 ghost · ⚠️ privacy infra DOWN (bridge=$HC proxy=${EXIT_IP:-down}) -- hosted unreachable, falling back to LOCAL 32B (offline)"
  fi
fi
if scutil --dns 2>/dev/null | grep -q "103.86.9"; then VPN="✅ NordVPN"; else VPN="⚠️ no NordVPN"; fi
[ -n "$PASS_PATHS" ] && STATUS="$STATUS · 🗂️ path-aware (real paths visible to hosted model)"
echo "$STATUS · $VPN" >&2

HB="__ENG__/venv/bin/hermes"
if [ -n "$PASS_PATHS" ]; then
  : > "$SENTINEL"
  trap 'rm -f "$SENTINEL"' EXIT INT TERM
  "$HB" -p uncensored "$@"
else
  rm -f "$SENTINEL" 2>/dev/null
  exec "$HB" -p uncensored "$@"
fi
