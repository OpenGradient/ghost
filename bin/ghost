#!/bin/sh
# ghost -- incognito agentic harness launcher (profile: uncensored).
#   Default model: LOCAL 32B abliterated (uncensored-local) -- fully offline, nothing leaves the box.
#   Optional hosted via /model: hermes-4-405b / hermes-4-70b -> PII scrubber (8788)
#     -> rotating Webshare proxy (8899) -> Nous.   Auxiliary tasks run on the local 7B (ghost-tool).
# Warns (never hard-blocks) if the privacy infra is down, so the offline default still runs.
SCRUBBER="http://127.0.0.1:8788"
PROXY="http://127.0.0.1:8899"
PY=__PYTHON__
SENTINEL="$HOME/.hermes/privacy/.pass_paths"

# --paths (or --code): path-aware mode -- let real filesystem paths reach 405B for agentic
# file work; name + secrets in content are still scrubbed. Default off = full redaction.
PASS_PATHS=""
case "${1:-}" in --paths|--code) PASS_PATHS=1; shift ;; esac

# Direct mode (GHOST_DIRECT install): no local privacy stack -- skip the gate, run straight.
if [ -f "$HOME/.hermes/.ghost-direct" ]; then
  echo "👻 ghost · direct (no local privacy stack) · default = Hermes 405B · local 32B fallback" >&2
  exec "__ENG__/venv/bin/hermes" -p uncensored "$@"
fi

# Self-heal the hosted inference route through the scrubber (a token refresh can reset it).
"$PY" "$HOME/.hermes/privacy/ensure_scrubber_route.py" 2>/dev/null || true

HC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$SCRUBBER/healthz" 2>/dev/null)
EXIT_IP=$(/usr/bin/curl -s --max-time 8 -x "$PROXY" https://api.ipify.org 2>/dev/null)
if [ "$HC" = "200" ] && [ -n "$EXIT_IP" ]; then
  STATUS="👻 ghost · default = Hermes 405B · scrubbed + proxied via $EXIT_IP · local 32B fallback"
else
  STATUS="👻 ghost · ⚠️ privacy infra DOWN (scrubber=$HC proxy=${EXIT_IP:-down}) -- 405B unreachable, falling back to LOCAL 32B (offline)"
fi
if scutil --dns 2>/dev/null | grep -q "103.86.9"; then VPN="✅ NordVPN"; else VPN="⚠️ no NordVPN"; fi
[ -n "$PASS_PATHS" ] && STATUS="$STATUS · 🗂️ path-aware (real paths visible to 405B)"
echo "$STATUS · $VPN" >&2
HB="__ENG__/venv/bin/hermes"
if [ -n "$PASS_PATHS" ]; then
  : > "$SENTINEL"
  trap 'rm -f "$SENTINEL"' EXIT INT TERM
  "$HB" -p uncensored "$@"
else
  rm -f "$SENTINEL" 2>/dev/null
  exec "$HB" -p uncensored "$@"
fi
