#!/bin/sh
# ghost -- incognito agentic harness launcher (profile: uncensored).
#   Default model: hosted nous/hermes-4-405b, reached through ghost's local scrubbing
#     bridge (127.0.0.1:8788) -> og-veil (127.0.0.1:11435) -> chat-api TEE gateway
#     (oblivious-HTTP + enclave; og-veil owns the OHTTP/registry/verification + auth).
#   On-demand via /model: drops to the fully-local 32B/7B (true incognito, nothing leaves).
# Warns (never hard-blocks) if the privacy infra is down or you're not logged in, so the
# offline local model still runs.
SCRUBBER="http://127.0.0.1:8788"
VEIL="http://127.0.0.1:11435"
PROXY="http://127.0.0.1:8899"
PY=__PYTHON__
SENTINEL="__GHOST_HOME__/privacy/.pass_paths"
export HERMES_HOME="__GHOST_HOME__"   # ghost's isolated state dir (the engine honors HERMES_HOME)

# Strip an ambient ANTHROPIC_API_KEY so any `claude` the agent shells out to uses your
# Claude subscription (OAuth) instead of an empty-credit pay-per-use API key. ghost itself
# infers through the OG TEE gateway and never needs this key.
unset ANTHROPIC_API_KEY

# --paths (or --code): path-aware mode -- let real filesystem paths reach the hosted model
# for agentic file work; name + secrets in content are still scrubbed. Default off = full redaction.
PASS_PATHS=""
case "${1:-}" in --paths|--code) PASS_PATHS=1; shift ;; esac

# --no-scrub / --scrub: persistent toggle for name/PII redaction. Secrets (API keys, JWTs,
# private keys) are ALWAYS scrubbed regardless. Turn off when redaction mangles an essential
# query (e.g. your own domain in the prompt). State persists across runs; status line shows it.
NOSCRUB_MARK="__GHOST_HOME__/privacy/.no_scrub"
case "${1:-}" in
  --no-scrub|--noscrub) : > "$NOSCRUB_MARK"; shift ;;
  --scrub) rm -f "$NOSCRUB_MARK"; shift ;;
esac

# --preview "<text>": show exactly what the PII scrubber would redact (entity table +
# before/after + restore map) WITHOUT sending anything. Lets you see what leaves the box.
if [ "${1:-}" = "--preview" ]; then shift; exec "$PY" "__GHOST_HOME__/privacy/presidio_scrub.py" "$@"; fi

# Are we connected to a hosted account?  (hosted models need `ghost-login` -> og-veil login.)
if "$PY" -m veil status >/dev/null 2>&1; then LOGIN="✅ connected"; else LOGIN="⚠️ not logged in (run: ghost-login)"; fi

# Self-heal the hosted inference route through the scrubber (a token refresh can reset it).
"$PY" "__GHOST_HOME__/privacy/ensure_scrubber_route.py" 2>/dev/null || true

# Is the local scrubbing bridge up, and is og-veil (which carries the hosted request) up?
HC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$SCRUBBER/healthz" 2>/dev/null)
VC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$VEIL/health" 2>/dev/null)

# What does the primary fail over to? Local models are opt-in (GHOST_LOCAL at install); by
# default the fallback is a hosted 70B over the same private path -- no Ollama. Detect which.
if grep -q "provider: ollama-local" "__GHOST_HOME__/profiles/uncensored/config.yaml" 2>/dev/null; then
  FB="local 32B fallback"; FB_DOWN="falling back to LOCAL 32B (offline)"
else
  FB="hosted 70B fallback"; FB_DOWN="no local fallback (hosted-only -- set GHOST_LOCAL=1 at install for offline)"
fi

if [ "$HC" = "200" ] && [ "$VC" = "200" ]; then
  # Direct is the default: og-veil talks to chat-api itself (content stays private via
  # OHTTP/TEE). If the optional rotating proxy (GHOST_PROXY=1) is up, og-veil's egress is
  # IP-masked through it -- we probe its exit IP purely for the status line.
  EXIT_IP=$(/usr/bin/curl -s --max-time 6 -x "$PROXY" https://api.ipify.org 2>/dev/null)
  if [ -n "$EXIT_IP" ]; then
    STATUS="👻 ghost · default = Hermes 405B via TEE gateway (OHTTP/og-veil) · IP-masked via $EXIT_IP · $LOGIN · $FB"
  else
    STATUS="👻 ghost · direct · default = Hermes 405B via TEE gateway (OHTTP/og-veil) · $LOGIN · $FB"
  fi
elif [ "$HC" = "200" ]; then
  STATUS="👻 ghost · ⚠️ og-veil DOWN (veil=$VC) -- hosted unreachable (try ghost-login), $FB_DOWN"
else
  STATUS="👻 ghost · ⚠️ scrubbing bridge DOWN (bridge=$HC) -- hosted unreachable, $FB_DOWN"
fi
[ -n "$PASS_PATHS" ] && STATUS="$STATUS · 🗂️ path-aware (real paths visible to hosted model)"
[ -f "$NOSCRUB_MARK" ] && STATUS="$STATUS · 🔓 PII redaction OFF (secrets still scrubbed)"
# NER scrubber expected but failed to load -> regex fallback (names may not be scrubbed). Loud.
[ -f "__GHOST_HOME__/privacy/.presidio_failed" ] && STATUS="$STATUS · ⚠️ NER scrubber OFF (regex fallback -- reinstall or check Presidio)"
echo "$STATUS" >&2

HB="__ENG__/venv/bin/hermes"
if [ -n "$PASS_PATHS" ]; then
  : > "$SENTINEL"
  trap 'rm -f "$SENTINEL"' EXIT INT TERM
  "$HB" -p uncensored "$@"
else
  rm -f "$SENTINEL" 2>/dev/null
  exec "$HB" -p uncensored "$@"
fi
