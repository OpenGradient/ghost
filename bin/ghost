#!/bin/sh
# ghost -- incognito agentic harness launcher (profile: uncensored).
#   Default model: hosted nous/hermes-4-405b, reached through ghost's local scrubbing
#     bridge (127.0.0.1:8788) -> og-veil (127.0.0.1:11435) -> chat-api TEE gateway
#     (oblivious-HTTP + enclave; og-veil owns the OHTTP/registry/verification + auth).
#   On-demand via /model: drops to the fully-local 32B/7B (true incognito, nothing leaves).
# Warns (never hard-blocks) if the privacy infra is down or you're not logged in, so the
# offline local model still runs.
SCRUBBER="http://127.0.0.1:8788"
VEIL="http://127.0.0.1:11435"
PY=__PYTHON__
SENTINEL="__GHOST_HOME__/privacy/.pass_paths"
export HERMES_HOME="__GHOST_HOME__"   # ghost's isolated state dir (the engine honors HERMES_HOME)

# Strip an ambient ANTHROPIC_API_KEY so any `claude` the agent shells out to uses your
# Claude subscription (OAuth) instead of an empty-credit pay-per-use API key. ghost itself
# infers through the OG TEE gateway and never needs this key.
unset ANTHROPIC_API_KEY

# --paths (or --code): path-aware mode -- let real filesystem paths reach the hosted model
# for agentic file work; name + secrets in content are still scrubbed. Default off = full redaction.
PASS_PATHS=""
case "${1:-}" in --paths|--code) PASS_PATHS=1; shift ;; esac

# --scrub / --no-scrub: persistent toggle for OUTBOUND PII + secret redaction. OFF BY DEFAULT --
# ghost is a full-fidelity agent (so it can do real work, incl. authorized pentesting, without its
# own privacy layer mangling secrets it reads). og-veil still OHTTP-encrypts + TEE-isolates the
# hosted path regardless. Turn it ON only to strip your own name/secrets before the gateway.
SCRUB_MARK="__GHOST_HOME__/privacy/.scrub"
case "${1:-}" in
  --scrub) : > "$SCRUB_MARK"; shift ;;
  --no-scrub|--noscrub) rm -f "$SCRUB_MARK"; shift ;;
esac

# --preview "<text>": show exactly what the PII scrubber would redact (entity table +
# before/after + restore map) WITHOUT sending anything. Lets you see what leaves the box.
if [ "${1:-}" = "--preview" ]; then shift; exec "$PY" "__GHOST_HOME__/privacy/presidio_scrub.py" "$@"; fi

# --local: force the fully-offline local model for this run (true incognito -- nothing leaves the
# box, no scrubber/og-veil/network). Requires a local install (GHOST_LOCAL=1). Picks the local
# model from the ollama-local provider's default_model in config (uncensored-local 32B if present,
# else ghost-tool 7B). Without a local model installed, tells you how to get one.
if [ "${1:-}" = "--local" ]; then
  shift
  LM=$(grep -A4 '^  ollama-local:' "__GHOST_HOME__/profiles/uncensored/config.yaml" 2>/dev/null \
        | grep 'default_model:' | head -1 | sed 's/.*default_model:[[:space:]]*//')
  [ -n "$LM" ] || LM="ghost-tool:latest"
  OLLAMA_BIN="$(command -v ollama || echo /opt/homebrew/bin/ollama)"
  if ! "$OLLAMA_BIN" list 2>/dev/null | grep -q "$(printf '%s' "$LM" | cut -d: -f1)"; then
    echo "👻 ghost · ⚠️ no local model installed ($LM). Reinstall with GHOST_LOCAL=1 to add the offline model." >&2
    exit 1
  fi
  echo "👻 ghost · 🔒 LOCAL mode = $LM (fully offline -- no scrubber, no og-veil, nothing leaves the box)" >&2
  exec "__ENG__/venv/bin/hermes" -p uncensored -m "$LM" --provider ollama-local "$@"
fi

# Are we connected to a hosted account?  (hosted models need `ghost-login` -> og-veil login.)
if "$PY" -m veil status >/dev/null 2>&1; then LOGIN="✅ connected"; else LOGIN="⚠️ not logged in (run: ghost-login)"; fi

# Self-heal the hosted inference route through the scrubber (a token refresh can reset it).
"$PY" "__GHOST_HOME__/privacy/ensure_scrubber_route.py" 2>/dev/null || true

# Is the local scrubbing bridge up, and is og-veil (which carries the hosted request) up?
HC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$SCRUBBER/healthz" 2>/dev/null)
VC=$(/usr/bin/curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$VEIL/health" 2>/dev/null)

# Read the ACTUAL default + fallback models from config (bare names) so the banner never goes
# stale when the default changes.
CFG="__GHOST_HOME__/profiles/uncensored/config.yaml"
DEF_MODEL=$(awk '/^model:/{f=1;next} f&&/^  default:/{sub(/.*\//,"",$2);print $2;exit} f&&/^[^ ]/{exit}' "$CFG" 2>/dev/null)
[ -n "$DEF_MODEL" ] || DEF_MODEL="model"
FB_MODEL=$(awk '/^fallback_model:/{f=1;next} f&&/^  model:/{sub(/.*\//,"",$2);print $2;exit} f&&/^[^ ]/{exit}' "$CFG" 2>/dev/null)
if grep -A2 "^fallback_model:" "$CFG" 2>/dev/null | grep -q "provider: ollama-local"; then
  FB="fallback: ${FB_MODEL:-local} (offline)"; FB_DOWN="falling back to local ${FB_MODEL:-model} (offline)"
else
  FB="fallback: ${FB_MODEL:-hermes-4-70b}"; FB_DOWN="no offline fallback (hosted-only)"
fi

# Privacy comes from og-veil: every request is HPKE/OHTTP-encrypted, so the relay only ever sees
# ciphertext (the "via TEE gateway (OHTTP)" below). The relay still sees your IP; for full
# anonymity use the local model (ghost --local), which has zero egress.

if [ "$HC" = "200" ] && [ "$VC" = "200" ]; then
  STATUS="👻 ghost · $DEF_MODEL via TEE gateway (OHTTP/og-veil) · $LOGIN · $FB"
elif [ "$HC" = "200" ]; then
  STATUS="👻 ghost · ⚠️ og-veil DOWN (veil=$VC) -- hosted unreachable (try ghost-login), $FB_DOWN"
else
  STATUS="👻 ghost · ⚠️ scrubbing bridge DOWN (bridge=$HC) -- hosted unreachable, $FB_DOWN"
fi
[ -n "$PASS_PATHS" ] && STATUS="$STATUS · 🗂️ path-aware (real paths visible to hosted model)"
if [ -f "$SCRUB_MARK" ]; then STATUS="$STATUS · 🔒 redaction ON (PII+secrets scrubbed outbound)"; else STATUS="$STATUS · 🔓 no redaction (full fidelity; og-veil still encrypts)"; fi
# NER scrubber expected but failed to load -> regex fallback (names may not be scrubbed). Loud.
[ -f "__GHOST_HOME__/privacy/.presidio_failed" ] && STATUS="$STATUS · ⚠️ NER scrubber OFF (regex fallback -- reinstall or check Presidio)"
echo "$STATUS" >&2

HB="__ENG__/venv/bin/hermes"
if [ -n "$PASS_PATHS" ]; then
  : > "$SENTINEL"
  trap 'rm -f "$SENTINEL"' EXIT INT TERM
  "$HB" -p uncensored "$@"
else
  rm -f "$SENTINEL" 2>/dev/null
  exec "$HB" -p uncensored "$@"
fi
