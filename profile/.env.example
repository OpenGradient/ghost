# Copy to the installed profile as .env. No API keys needed: local models need none, and
# hosted models authenticate with the Supabase session captured by `ghost-login` (stored at
# ~/.ghost/privacy/chat_auth.json and used by the OHTTP bridge -- not via env here).
#
# All of the ENGINE's own egress (web search, fetches) is forced through the local rotating
# proxy to hide your IP; ddgs honors DDGS_PROXY (it ignores HTTPS_PROXY). The hosted-model
# path does NOT use these vars -- the OHTTP bridge (127.0.0.1:8788) chains to chat-api on its
# own, and localhost is excluded via NO_PROXY so the engine reaches the bridge directly.
HTTPS_PROXY=http://127.0.0.1:8899
HTTP_PROXY=http://127.0.0.1:8899
ALL_PROXY=http://127.0.0.1:8899
NO_PROXY=127.0.0.1,localhost,::1,0.0.0.0
DDGS_PROXY=http://127.0.0.1:8899
