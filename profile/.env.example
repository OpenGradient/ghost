# Copy to the installed profile as .env. No API keys needed for local-default incognito
# (local models need none; hosted Nous uses OAuth in auth.json). All egress is forced
# through the local rotating proxy; ddgs honors DDGS_PROXY (it ignores HTTPS_PROXY).
HTTPS_PROXY=http://127.0.0.1:8899
HTTP_PROXY=http://127.0.0.1:8899
ALL_PROXY=http://127.0.0.1:8899
NO_PROXY=127.0.0.1,localhost,::1,0.0.0.0
DDGS_PROXY=http://127.0.0.1:8899
NOUS_INFERENCE_BASE_URL=http://127.0.0.1:8788/v1
